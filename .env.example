# LoRaWAN-SIM + OpenClaw 插件（复制为 .env 或写入 shell 配置；勿提交含真实密钥的 .env）
#
# 模拟器运行目录：推荐指向本仓库 simulator/，或仅指向仓库根（插件会自动解析 simulator/）
LORAWAN_SIM_PROJECT_PATH=/absolute/path/to/LoRaWAN-SIM/simulator
#
# 模拟器（index.js）：覆盖 v2 配置里的 LNS 地址（UDP/MQTT 均依赖解析后的 lnsHost）
#LORAWAN_SIM_LNS_HOST=127.0.0.1
#
# simulator npm run dev：dev-sim-entry.sh 使用的配置文件路径（默认 configs/config.json）
#LORAWAN_SIM_CONFIG=configs/config.json
#
# scripts/chirpstack-provision-otaa-from-config.mjs 会默认加载仓库根目录的 .env（不覆盖已在 shell 里 export 的变量）。
# 另可：node scripts/chirpstack-provision-otaa-from-config.mjs --env-file /path/to/.env <config.json>
# 清空某应用下全部设备后按 JSON 重建：… --replace-all <config.json>

# ChirpStack REST API（与 openclaw-lorawan-sim 插件一致）
CHIRPSTACK_API_URL=http://10.0.0.3:8090
CHIRPSTACK_API_TOKEN=
CHIRPSTACK_APPLICATION_ID=540a999c-9eeb-4c5c-bed1-778dacddaf46
# 网关自动登记 scripts/chirpstack-ensure-gateways-from-config.mjs 需要租户；未填则使用租户列表第一个
CHIRPSTACK_TENANT_ID=81d48efb-6216-4c7f-8c21-46a5eac9d737
CHIRPSTACK_DEVICE_PROFILE_ID=a1b2c3d4-1111-2222-3333-444444444444
# 若 REST 返回 401，可改为 Authorization（默认与 openclaw 插件一致为 Grpc-Metadata-Authorization）
# CHIRPSTACK_AUTH_HEADER=Authorization
# 可选：rest | grpc
# CHIRPSTACK_API_STYLE=rest

# ===== UI Orchestrator 发布开关（灰度/回滚）=====
# 是否启用新编排 API（/resources/*, /layout/apply, /sync/retry）
ENABLE_ORCHESTRATOR_API=true
# 是否允许编排层写 ChirpStack（false 时自动降级为 simulator_only）
ENABLE_CHIRPSTACK_SYNC=true
