{
  "description": "Complete template for CN470 OTAA devices - ready for ChirpStack sync",
  "gatewayEui": "GATEWAY_EUI_PLACEHOLDER",
  
  // Option A: UDP direct connection to Gateway Bridge (recommended for CN470)
  "lnsHost": "10.5.40.109",
  "lnsPort": 1700,  // CN470 uses port 1700, AS923 uses 1702, KR920 uses 1701
  
  // Option B: MQTT connection through broker
  "mqtt": {
    "enabled": true,  // Set to false if using UDP (lnsHost/lnsPort)
    "server": "tcp://10.5.40.109:1883",  // Remote MQTT broker
    // "server": "tcp://127.0.0.1:1883",  // Local MQTT broker (if running locally)
    "username": "",
    "password": "",
    "clientId": "lorawan-gw-sim-cn470",
    "clean": true,
    "qos": 0,
    "marshaler": "protobuf",
    "topicPrefix": "cn470_10"  // Must match gateway.properties.region_config_id
    // For AS923: "as923", for KR920: "kr920"
  },
  
  "lorawan": {
    "enabled": true,
    "activation": "OTAA",
    "class": "C",  // Class C for continuous reception (recommended for testing)
    "csvImportPath": "configs/synced-devices.csv",  // Will be populated by lorawan_sim_sync_from_chirpstack
    "appKey": "00112233445566778899AABBCCDDEEFF"  // Unified AppKey for all test devices
  },
  
  "uplink": {
    "enabled": true,
    "codec": "simple",  // simple, hex, base64
    "payloadLength": 4,  // Bytes per uplink
    "interval": 60000,   // 60 seconds between uplinks
    "scatterMode": "uniform",  // uniform, random, none
    "region": "AS923-1",  // Simulator only supports AS923-1 in REGIONS object
    
    // CN470 channels override - simulator doesn't have CN470 in REGIONS
    "nodeState": {
      "channels": [
        470.3, 470.5, 470.7, 470.9, 471.1, 471.3, 471.5, 471.7, 471.9, 472.1,
        472.3, 472.5, 472.7, 472.9, 473.1, 473.3, 473.5, 473.7, 473.9, 474.1,
        474.3, 474.5, 474.7, 474.9, 475.1, 475.3, 475.5, 475.7, 475.9, 476.1,
        476.3, 476.5, 476.7, 476.9, 477.1, 477.3, 477.5, 477.7, 477.9, 478.1,
        478.3, 478.5, 478.7, 478.9, 479.1, 479.3, 479.5, 479.7, 479.9, 480.1,
        480.3, 480.5, 480.7, 480.9, 481.1, 481.3, 481.5, 481.7, 481.9, 482.1,
        482.3, 482.5, 482.7, 482.9, 483.1, 483.3, 483.5, 483.7, 483.9, 484.1,
        484.3, 484.5, 484.7, 484.9, 485.1, 485.3, 485.5, 485.7, 485.9, 486.1,
        486.3, 486.5, 486.7, 486.9, 487.1, 487.3, 487.5, 487.7, 487.9, 488.1,
        488.3, 488.5, 488.7, 488.9, 489.1, 489.3
      ],
      "txPowerIndex": 0,  // 0-7
      "rssi": -85,
      "snr": 5
    }
  },
  
  "stats": {
    "enabled": true,
    "intervalMs": 60000
  },
  
  // Enable control server for device reset via lorawan_sim_reset_device
  "controlServer": {
    "enabled": true,
    "port": 9999
  }
}